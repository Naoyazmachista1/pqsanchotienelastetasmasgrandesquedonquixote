al--;\n    }\n\n    @Override\n    public void dibujar(Graphics2D g) {\n        // Forma de célula con \"receptores\" (protuberancias)\n        g.setColor(color);\n        g.fillOval(x - tamaño / 2, y - tamaño / 2, tamaño, tamaño);\n\n        // Receptores de membrana (característica de linfocitos)\n        g.setColor(esJugador ? new Color(0, 150, 255) : new Color(150, 200, 255));\n        for (int i = 0; i < 8; i++) {\n            double ang = (i / 8.0) * 2 * Math.PI;\n            int rx = x + (int)(Math.cos(ang) * (tamaño / 2 + 5));\n            int ry = y + (int)(Math.sin(ang) * (tamaño / 2 + 5));\n            g.fillOval(rx - 3, ry - 3, 6, 6);\n        }\n\n        // Indicador de cooldown\n        if (cooldownActual > 0) {\n            g.setColor(Color.YELLOW);\n            g.drawArc(x - tamaño / 2, y - tamaño / 2, tamaño, tamaño, 90,\n                (int)(360.0 * cooldownActual / cooldownAtaque));\n        }\n\n        // Barra de vida\n        g.setColor(Color.RED);\n        g.fillRect(x - 15, y - tamaño / 2 - 10, 30, 4);\n        g.setColor(Color.GREEN);\n        g.fillRect(x - 15, y - tamaño / 2 - 10, (int)(30.0 * vida / 50), 4);\n    }\n\n    public int getDañoAtaque() { return dañoAtaque; }\n    public boolean esJugador() { return esJugador; }\n"]]},{"start1":5897,"length1":157,"diffs":[[1,"// Macrófago - Come patógenos\nclass Macrofago extends Entidad {\n    private int capacidadFagocitosis;\n"]]},{"start1":6000,"length1":240,"diffs":[[1,"    public Macrofago(int x, int y) {\n        super(x, y, 2, 80, 50, new Color(255, 140, 0), \"Macrófago\");\n        this.capacidadFagocitosis = 3;\n    }\n"]]},{"start1":6152,"length1":109,"diffs":[[1,"    @Override\n    public void mover(int ancho, int alto) {\n        Random rand = new Random();\n        x += (rand.nextInt(3) - 1) * velocidad;\n        y += (rand.nextInt(3) - 1) * velocidad;\n        x = Math.max(tamaño / 2, Math.min(ancho - tamaño / 2, x));\n        y = Math.max(tamaño / 2, Math.min(alto - tamaño /