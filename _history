      }\n            }\n        }\n    }\n\n    // Cáncer daña al jugador y aliados\n    for (CelulaCancerigena c : cancerigenas) {\n        if (c.colisionaCon(jugador)) {\n            jugador.recibirDaño(c.getDaño());\n        }\n        for (LinfocitoT aliado : aliados) {\n            if (c.colisionaCon(aliado)) {\n                aliado.recibirDaño(c.getDaño());\n            }\n        }\n    }\n\n    // Limpiar aliados muertos\n    aliados.removeIf(a -> !a.estaVivo());\n\n    // Actualizar partículas\n    for (ParticulaEducativa p : new ArrayList<>(particulas)) {\n        p.actualizar();\n    }\n    particulas.removeIf(p -> !p.estaActiva());\n\n    // Verificar condiciones de juego\n    if (vidasSistemaInmune <= 0 || !jugador.estaVivo()) {\n        juegoActivo = false;\n    }\n\n    if (cancerigenas.isEmpty() && juegoActivo) {\n        nivel++;\n        spawnEnemigos(3 + nivel * 2);\n        if (nivel % 2 == 0) spawnAliados(1);\n        vidasSistemaInmune = Math.min(100, vidasSistemaInmune + 20);\n        particulas.add(new ParticulaEducativa(getWidth() / 2, getHeight() / 2,\n            \"¡Nivel \" + nivel + \"! El cáncer se vuelve más agresivo\"));\n    }\n\n    // Rotar datos cada cierto tiempo\n    if (timer.getDelay() % 300 == 0) datoActual++;\n}\n\n// Controles del mouse\n@Override\npublic void mouseMoved(MouseEvent e) {\n    mouseX = e.getX();\n    mouseY = e.getY();\n}\n\n@Override\npublic void mouseDragged(MouseEvent e) {\n    mouseX = e.getX();\n    mouseY = e.getY();\n}\n\n@Override\npublic void mouseClicked(MouseEvent e) {\n    if (!juegoActivo) return;\n\n    // Ataque en área alrededor del click\n    for (CelulaCancerigena c : cancerigenas) {\n        int dist = (int) Math.sqrt(Math.pow(c.getX() - e.getX(), 2) +\n            Math.pow(c.getY() - e.getY(), 2));\n        if (dist < 100 && jugador.puedeAtacar()) {\n            c.recibirDaño(jugador.getDañoAtaque() * 2);\n            // Efecto visual de ataque\n            particulas.add(new ParticulaEd